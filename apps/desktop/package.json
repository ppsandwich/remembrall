{
  "name": "@remembrall/desktop",
  "version": "0.0.3",
  "description": "Remembrall - Capture and organize your thoughts",
  "author": "Sandwich Codes",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsx src/main/index.ts",
    "build": "tsc && electron-builder",
    "build:mac": "tsc && electron-builder --mac",
    "build:win": "tsc && electron-builder --win",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "dmg-license": "^1.0.11",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "codes.sandwich.remembrall",
    "productName": "Remembrall",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "web-out/**/*"
    ],
    "extraResources": [
      {
        "from": "web-out",
        "to": "web-out",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
