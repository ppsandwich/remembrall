{
  "name": "brall",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @brall/web dev",
    "dev:desktop": "pnpm --filter @brall/desktop dev",
    "build": "pnpm --filter @brall/web build",
    "build:desktop": "pnpm --filter @brall/desktop build",
    "build:desktop:mac": "pnpm --filter @brall/desktop build:mac",
    "build:desktop:win": "pnpm --filter @brall/desktop build:win",
    "build:extension": "npx tsx scripts/build-extension.ts",
    "lint": "pnpm --filter @brall/web lint",
    "typecheck": "pnpm run -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "playwright": "^1.61.1",
    "vitest": "^4.1.9"
  }
}
